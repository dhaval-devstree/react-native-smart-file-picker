{
  "name": "react-native-smart-file-picker",
  "version": "1.0.0",
  "description": "Smart file picker for React Native (Android & iOS) with dynamic bottom-sheet UI, camera/gallery/document support, crop and compression.",
  "license": "MIT",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "android/",
    "ios/",
    "src/",
    "lib/",
    "react-native-smart-file-picker.podspec",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf lib",
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.build.json --module ESNext --outDir lib/module",
    "prepack": "yarn build"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-native": ">=0.71",
    "react-native-permissions": ">=3"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "react-native-permissions": "^5.5.0",
    "typescript": "^5.5.4"
  }
}